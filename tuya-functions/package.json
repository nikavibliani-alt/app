{
  "name": "tuya-functions",
  "version": "1.0.0",
  "description": "Firebase Cloud Functions for Tuya lock integration",
  "engines": { "node": "22" },
  "main": "index.js",
  "scripts": {
    "deploy": "firebase deploy --only functions",
    "deploy:generate": "firebase deploy --only functions:generateOfflinePasswordOnReservation",
    "deploy:regenerate": "firebase deploy --only functions:regenerateTuyaPassword",
    "deploy:delete": "firebase deploy --only functions:deleteTuyaPassword"
  },
  "dependencies": {
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^5.0.0"
  },
  "private": true
}
